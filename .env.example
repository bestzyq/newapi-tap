# ============ 数据库配置 ============
# newapi 数据库（查询 logs 表统计用量，读写 channels/abilities 表控制水龙头）
NEWAPI_DB_HOST=localhost
NEWAPI_DB_USER=newapi
NEWAPI_DB_PASS=newapi
NEWAPI_DB_NAME=newapi

# newapi-tap 自身数据库（读写，存储状态和日志）
TAP_DB_HOST=localhost
TAP_DB_USER=newapi_tap
TAP_DB_PASS=newapi_tap
TAP_DB_NAME=newapi_tap

# ============ 站点配置 ============
# 网站名称（显示在页面标题和头部）
SITE_NAME=NewAPI-TAP
# API 站点地址（用于"返回API站"按钮的链接，留空则不显示）
API_SITE_URL=https://your-api-site.com
# 公告横幅内容（显示在页面顶部，留空则不显示）
ANNOUNCEMENT=

# ============ 每月免费额度配置 ============
# 月度总额度（单位：token），仅用于 shared 模式渠道的总额度
MONTHLY_TOKENS=100000000

# ============ 水龙头渠道配置 ============
#
# 格式（受控渠道）：渠道ID:模式:额度:统计:开启分组:关闭分组
# 格式（不限量渠道）：渠道ID:unlimited:0:统计
#
# 渠道ID — newapi 中 channels 表的 id
#
# 模式：
#   shared    — 共享月度总额度，按剩余天数均分（额度字段填 0）
#   monthly   — 独立月度额度，按剩余天数均分（额度字段填月度 token 数）
#   daily     — 独立日额度，每日固定额度，不参与月度总额计算（额度字段填每日 token 数）
#   unlimited — 不限量，仅监控用量和显示模型，不控制水龙头开关
#
# 统计：
#   all  — 统计该渠道全部调用（默认，含付费和免费用户）
#   free — 仅统计 free 组用户的调用
#
# 开启分组 — 水龙头开启时的分组（包含免费组）
# 关闭分组 — 水龙头关闭时的分组（不含免费组）
# （unlimited 模式不需要填写分组）
#
# 多个渠道用分号分隔
# 示例：
#   渠道35: shared模式，统计全部调用
#   渠道36: monthly模式，每月5000万token，仅统计免费调用
#   渠道37: daily模式，每日200万token，统计全部调用
#   渠道38: unlimited模式，不限量，仅监控，统计全部调用
TAP_CHANNELS=35:shared:0:all:default,vip,svip,free:default,vip,svip

# ============ 时间配置 ============
CHECK_INTERVAL=300

# ============ 日志保留天数 ============
LOG_RETENTION_DAYS=90

# ============ 访问密钥（可选，为空则不验证） ============
ACCESS_KEY=
